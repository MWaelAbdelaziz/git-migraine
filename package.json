{
  "name": "git-migraine",
  "version": "0.1.1",
  "description": "Automatically apply and undo Sequelize migrations when you switch git branches. A cure for migration headaches.",
  "keywords": [
    "sequelize",
    "sequelize-cli",
    "migrations",
    "git",
    "git-hooks",
    "post-checkout",
    "husky",
    "database"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "git-migraine": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
